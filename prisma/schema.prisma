generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  emailVerified DateTime?
  name          String?
  role          Role         @default(BUYER)
  createdAt     DateTime     @default(now())

  phone         String?
  contactPref   String?
  whatsapp      String?
  telegram      String?
  reraNumber    String?

  listings      Listing[]
  savedListings SavedListing[]
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]
}

enum Role {
  GUEST
  BUYER
  AGENT
}

model Listing {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  expiresAt     DateTime

  status        ListingStatus   @default(ACTIVE)
  listingType   ListingType     @default(SALE)

  title         String
  projectName   String
  location      String
  subLocation   String?

  propertyType  PropertyType
  bedrooms      String
  bathrooms     String?

  areaSqft      Float?
  areaSqm       Float?
  plotSqft      Float?
  plotSqm       Float?

  price         Float
  priceLabel    String?

  floor         FloorType?
  view          String?
  furnished     FurnishedStatus?

  handover      String?
  handoverDate  DateTime?

  isDistress    Boolean         @default(false)
  originalPrice Float?

  parkingSpots  Int?
  isRented      Boolean         @default(false)
  rentAmount    Float?
  rentedUntil   String?

  description   String?
  viewCount     Int             @default(0)

  agentId       String
  agent         User            @relation(fields: [agentId], references: [id])

  savedBy       SavedListing[]
  notifications Notification[]
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
}

enum ListingType {
  SALE
  RENT
}

enum PropertyType {
  APARTMENT
  TOWNHOUSE
  VILLA
  PENTHOUSE
  DUPLEX
}

enum FloorType {
  LOW
  MIDDLE
  HIGH
}

enum FurnishedStatus {
  FURNISHED
  UNFURNISHED
  PARTIAL
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  listingId String?
  type      NotifType
  message   String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
}

enum NotifType {
  LISTING_EXPIRING
  LISTING_EXPIRED
  CONTACT_REVEALED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
